# Seq Widget — example configuration
# Copy this file to .env and fill in the keys you want to use.
# Only the providers with filled keys will be active.

# Which provider to prefer when multiple are configured.
# Options: groq | openai | gemini | openrouter | ollama
SEQ_ACTIVE_PROVIDER=groq

# ── Cloud providers (only fill in the ones you use) ──────────────
SEQ_GROQ_API_KEY=
SEQ_OPENAI_API_KEY=
SEQ_GEMINI_API_KEY=
SEQ_OPENROUTER_API_KEY=

# ── Ollama (local LLMs) ──────────────────────────────────────────
# Leave blank to disable. Set to your Ollama server URL to enable.
SEQ_OLLAMA_URL=
SEQ_OLLAMA_MODEL=llama3
